# mcp-incidentiq .gitignore
# Stack: Bun / TypeScript
# Last updated: 2026-06-14
# Ignores dependencies, build artifacts, IDE/OS files, secrets, and local tooling state.

# ============================================================================
# Dependencies (Bun)
# ============================================================================
node_modules/

# ============================================================================
# Foreign lock files (this is a Bun project - never commit other managers')
# ============================================================================
package-lock.json
pnpm-lock.yaml
yarn.lock

# ============================================================================
# Build output
# ============================================================================
*.tsbuildinfo
build/
dist/

# ============================================================================
# Testing
# ============================================================================
.nyc_output/
coverage/

# ============================================================================
# Environment variables (allow the committed example template)
# ============================================================================
.env
.env.*.local
.env.local
!.env.example

# ============================================================================
# Logs
# ============================================================================
*.log
logs/
npm-debug.log*

# ============================================================================
# Temporary files
# ============================================================================
*.tmp
temp/
tmp/

# ============================================================================
# OS-Specific
# ============================================================================
.DS_Store
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini
ehthumbs.db

# ============================================================================
# IDE (.vscode/ is intentionally committed for shared settings)
# ============================================================================
*.swo
*.swp
*~
.idea/

# ============================================================================
# AI agents & local tooling state
# ============================================================================
.claude/
.codegraph/
CLAUDE.local.md
context/
docs/plans/
docs/prd/
