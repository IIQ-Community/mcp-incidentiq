# mcp-incidentiq .gitignore
# Stack: Node.js / TypeScript (Yarn 4)
# Last updated: 2026-06-13
# Ignores dependencies, build artifacts, IDE/OS files, secrets, and local tooling state.

# ============================================================================
# Dependencies (Node.js / Yarn 4)
# ============================================================================
.pnp.*
.yarn/*
!.yarn/cache
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
node_modules/

# ============================================================================
# Foreign lock files (this is a Yarn project - never commit other managers')
# ============================================================================
bun.lockb
package-lock.json
pnpm-lock.yaml

# ============================================================================
# Build output
# ============================================================================
*.tsbuildinfo
build/
dist/

# ============================================================================
# Testing
# ============================================================================
.nyc_output/
coverage/

# ============================================================================
# Environment variables (allow the committed example template)
# ============================================================================
.env
.env.*.local
.env.local
!.env.example

# ============================================================================
# Logs
# ============================================================================
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================================================
# Temporary files
# ============================================================================
*.tmp
temp/
tmp/

# ============================================================================
# OS-Specific
# ============================================================================
.DS_Store
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini
ehthumbs.db

# ============================================================================
# IDE (.vscode/ is intentionally committed for shared settings)
# ============================================================================
*.swo
*.swp
*~
.idea/

# ============================================================================
# AI agents & local tooling state
# ============================================================================
.claude/
.codegraph/
CLAUDE.local.md
context/
